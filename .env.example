# ==============================================================================
# GLOBAL ENVIRONMENT VARIABLES TEMPLATE
# Copy values to local config files in frontend/, backend/, microservices/
# ==============================================================================

# ------------------------------------------------------------------------------
# CORE BACKEND / API GATEWAY (Express.js)
# ------------------------------------------------------------------------------
PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/copilot_db
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT Security
JWT_SECRET=super_secret_jwt_signature_key_change_in_production
JWT_REFRESH_SECRET=super_secret_refresh_signature_key_change_in_production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Firebase Credentials (JSON string for service account or path)
FIREBASE_PROJECT_ID=copilot-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@copilot-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# Socket CORS Settings
SOCKET_CORS_ORIGIN=http://localhost:5173

# ------------------------------------------------------------------------------
# SPRING BOOT ENTERPRISE SERVICE
# ------------------------------------------------------------------------------
SPRING_PORT=8080
SPRING_MONGO_URI=mongodb://localhost:27017/copilot_db
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

# ------------------------------------------------------------------------------
# AI AGENT microservice (LangChain Node.js)
# ------------------------------------------------------------------------------
AI_PORT=5001
AI_RABBITMQ_URL=amqp://guest:guest@localhost:5672
AI_MONGO_URI=mongodb://localhost:27017/copilot_db
OPENAI_API_KEY=your_openai_api_key_here
# Optional LLaMA Local Endpoints
LLAMA_API_BASE_URL=http://localhost:11434/v1
VECTOR_DB_URL=http://localhost:8000
VECTOR_DB_API_KEY=your_vector_db_key_if_hosted

# ------------------------------------------------------------------------------
# FRONTEND SPA (Vite + React)
# ------------------------------------------------------------------------------
VITE_API_URL=http://localhost:5000/api/v1
VITE_SOCKET_URL=http://localhost:5000
VITE_FIREBASE_API_KEY=AIzaSyA1...
VITE_FIREBASE_AUTH_DOMAIN=copilot-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=copilot-project-id
VITE_FIREBASE_STORAGE_BUCKET=copilot-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
